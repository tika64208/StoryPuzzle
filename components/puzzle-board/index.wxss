.board {
  display: grid;
  gap: 0;
  user-select: none;
}

.slot {
  position: relative;
  aspect-ratio: 1 / 1;
  overflow: visible;
  background: transparent;
}

.piece {
  position: absolute;
  inset: -1px;
  border: none;
  border-radius: 0;
  overflow: hidden;
  transition: transform 0.14s ease-out;
  will-change: transform;
}

.piece-image,
.piece-fallback {
  position: absolute;
  display: block;
}

.piece-image {
  max-width: none;
}

.piece-fallback {
  inset: 0;
}

.piece-dragging {
  z-index: 8;
}

.piece-glowing {}

.piece-guide {
  z-index: 4;
}

.piece-guide-group {
  z-index: 3;
}

.piece-outline {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.outline-edge {
  position: absolute;
  background: rgba(122, 255, 247, 0.98);
  box-shadow:
    0 0 6px rgba(122, 255, 247, 0.98),
    0 0 14px rgba(72, 227, 255, 0.9),
    0 0 24px rgba(72, 227, 255, 0.65);
}

.outline-top,
.outline-bottom {
  left: 1px;
  right: 1px;
  height: 4px;
}

.outline-left,
.outline-right {
  top: 1px;
  bottom: 1px;
  width: 4px;
}

.outline-top {
  top: 1px;
}

.outline-right {
  right: 1px;
}

.outline-bottom {
  bottom: 1px;
}

.outline-left {
  left: 1px;
}

.piece-guide-outline,
.piece-guide-group-outline,
.slot-guide-target {
  position: absolute;
  inset: 6rpx;
  border-radius: 16rpx;
  pointer-events: none;
}

.piece-guide-group-outline {
  border: 3rpx solid rgba(255, 196, 88, 0.46);
  box-shadow:
    inset 0 0 0 2rpx rgba(255, 222, 162, 0.12),
    0 0 8rpx rgba(255, 176, 72, 0.4),
    0 0 20rpx rgba(255, 176, 72, 0.2);
  animation: guideGroupPulse 1.1s ease-in-out infinite;
}

.piece-guide-outline {
  border: 4rpx solid rgba(255, 211, 111, 0.96);
  box-shadow:
    0 0 10rpx rgba(255, 211, 111, 0.95),
    0 0 22rpx rgba(255, 172, 88, 0.68);
  animation: guidePulse 1.2s ease-in-out infinite;
}

.slot-guide-target {
  border: 4rpx dashed rgba(124, 255, 226, 0.98);
  box-shadow:
    inset 0 0 0 2rpx rgba(6, 28, 38, 0.12),
    0 0 10rpx rgba(124, 255, 226, 0.9),
    0 0 24rpx rgba(93, 186, 255, 0.52);
  animation: targetPulse 1s ease-in-out infinite alternate;
}

@keyframes guidePulse {
  0% {
    opacity: 0.72;
    transform: scale(0.985);
  }

  100% {
    opacity: 1;
    transform: scale(1);
  }
}

@keyframes guideGroupPulse {
  0% {
    opacity: 0.52;
  }

  100% {
    opacity: 0.94;
  }
}

@keyframes targetPulse {
  0% {
    opacity: 0.68;
    transform: scale(0.98);
  }

  100% {
    opacity: 1;
    transform: scale(1);
  }
}
