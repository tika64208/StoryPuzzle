.top-shell {
  padding: 24rpx;
  border-radius: 32rpx;
  background: linear-gradient(180deg, rgba(16, 47, 69, 0.7) 0%, rgba(8, 28, 43, 0.76) 100%);
  border: 1rpx solid rgba(184, 238, 255, 0.12);
  box-shadow:
    inset 0 2rpx 0 rgba(233, 251, 255, 0.12),
    inset 0 -12rpx 24rpx rgba(3, 13, 22, 0.22),
    16rpx 16rpx 32rpx rgba(2, 10, 18, 0.28);
}

.title-wrap {
  flex: 1;
}

.title {
  font-size: 34rpx;
  font-weight: 700;
  color: #eef9ff;
}

.subtitle {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #b7d6e5;
}

.meta-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.meta-item {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #ddf7ff;
  background: linear-gradient(180deg, rgba(24, 72, 101, 0.52) 0%, rgba(12, 38, 57, 0.62) 100%);
  border: 1rpx solid rgba(176, 232, 255, 0.1);
  box-shadow: inset 0 1rpx 0 rgba(233, 251, 255, 0.08);
}

.pause-btn {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, rgba(47, 149, 195, 0.96) 0%, rgba(114, 237, 220, 0.92) 100%);
  color: #effcff;
  font-size: 22rpx;
  border: 1rpx solid rgba(181, 240, 255, 0.14);
  box-shadow:
    inset 0 1rpx 0 rgba(242, 253, 255, 0.2),
    10rpx 10rpx 22rpx rgba(2, 10, 18, 0.22);
}
