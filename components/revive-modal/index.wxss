.mask {
  position: fixed;
  inset: 0;
  z-index: 30;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  background:
    radial-gradient(circle at 50% 10%, rgba(121, 222, 255, 0.12), transparent 28%),
    rgba(2, 8, 14, 0.72);
}

.dialog {
  width: 100%;
  padding: 34rpx 30rpx 26rpx;
  border-radius: 34rpx;
  background: linear-gradient(180deg, rgba(14, 43, 63, 0.82) 0%, rgba(8, 27, 42, 0.88) 100%);
  border: 1rpx solid rgba(180, 236, 255, 0.14);
  box-shadow:
    inset 0 2rpx 0 rgba(236, 251, 255, 0.14),
    inset 0 -16rpx 28rpx rgba(2, 12, 21, 0.22),
    18rpx 18rpx 36rpx rgba(2, 10, 18, 0.36);
  backdrop-filter: blur(30rpx);
}

.dialog-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #effbff;
}

.dialog-desc {
  margin-top: 18rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #bbd8e6;
}

.confirm-btn {
  margin-top: 26rpx;
}
