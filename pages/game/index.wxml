<view class="page-shell game-shell">
  <top-bar
    title="{{level.title}}"
    clue-tag="{{level.clueTag}}"
    time-text="{{timeText}}"
    energy="{{energy}}"
    bind:pause="handlePause"
  />

  <view class="card summary-card">
    <view class="row-between">
      <view class="card-title">操作说明</view>
      <view class="chip">{{level.sceneName}}</view>
    </view>
    <view class="card-desc">
      {{level.introText}} 默认情况下，所有碎片都可以继续拖动，玩家不会直接知道哪块已经放对。只有消耗 1 个定格符后，当前已经归位的碎片才会被锁住。
    </view>
  </view>

  <view class="card board-card">
    <puzzle-board
      slots="{{slots}}"
      rows="{{level.rows}}"
      cols="{{level.cols}}"
      bind:groupdrop="handleGroupDrop"
      bind:lockedpieceblocked="handleLockedPieceBlocked"
    />
  </view>

  <view wx:if="{{status !== 'success'}}" class="card controls-card">
    <view class="row-between">
      <view class="chip">移动次数 {{moves}}</view>
      <view class="chip">剩余提示 {{hintsLeft}}</view>
    </view>
    <view class="row-between tools-row">
      <view class="chip">定格符 {{unlockDragTools}}</view>
      <view class="chip">已定格 {{lockedPiecesCount}} 块</view>
    </view>
    <view class="control-grid">
      <button class="secondary-btn" bindtap="handleHint">使用提示</button>
      <button class="secondary-btn" bindtap="handleReset">重置拼图</button>
      <button class="secondary-btn unlock-btn" bindtap="handleUseUnlockTool">消耗 1 个定格符</button>
    </view>
  </view>

  <view wx:if="{{status === 'success'}}" class="card success-card">
    <view class="row-between">
      <view class="card-title">拼图完成</view>
      <view class="chip">可以先欣赏图片</view>
    </view>
    <view class="card-desc">图片会停留在当前页面，不会立刻跳走。想继续时，再点下面的按钮查看结算。</view>
    <image wx:if="{{previewImageSrc}}" class="success-image" src="{{previewImageSrc}}" mode="aspectFill"></image>
    <view class="stats-row">
      <view class="chip">剩余 {{timeText}}</view>
      <view class="chip">金币 +{{successCoins}}</view>
      <view class="chip">星级 {{successStars}}</view>
    </view>
    <button class="primary-btn action-gap" bindtap="handleOpenResult">查看结算</button>
  </view>

  <revive-modal
    visible="{{showRevive}}"
    time-bonus="{{reviveSeconds}}"
    bind:close="handleReviveClose"
    bind:confirm="handleReviveConfirm"
  />
</view>
