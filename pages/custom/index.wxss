.uploader {
  margin-top: 20rpx;
  height: 420rpx;
  border-radius: 28rpx;
  overflow: hidden;
  background: linear-gradient(180deg, rgba(12, 40, 58, 0.68) 0%, rgba(8, 27, 42, 0.72) 100%);
  border: 1rpx solid rgba(177, 232, 255, 0.12);
  box-shadow:
    inset 0 2rpx 0 rgba(235, 251, 255, 0.08),
    inset 0 -12rpx 22rpx rgba(3, 13, 22, 0.2),
    14rpx 14rpx 28rpx rgba(2, 10, 18, 0.24);
}

.uploader-image {
  width: 100%;
  height: 100%;
}

.uploader-empty {
  display: flex;
  height: 100%;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 28rpx;
  text-align: center;
}

.uploader-empty-title {
  font-size: 32rpx;
  font-weight: 600;
}

.uploader-empty-desc {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #b5d0de;
}

.uploader-btn,
.create-btn {
  margin-top: 20rpx;
}

.top-actions {
  margin-top: 20rpx;
}

.field-label {
  margin-top: 22rpx;
  font-size: 24rpx;
  color: #b9d5e4;
}

.text-input,
.picker-field,
.code-input {
  margin-top: 12rpx;
  width: 100%;
  padding: 22rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, rgba(14, 42, 61, 0.66) 0%, rgba(8, 25, 39, 0.72) 100%);
  border: 1rpx solid rgba(179, 236, 255, 0.1);
  font-size: 26rpx;
  color: #eef9ff;
  box-shadow:
    inset 0 2rpx 0 rgba(232, 251, 255, 0.08),
    inset 0 -10rpx 18rpx rgba(4, 12, 19, 0.18);
}

.code-input {
  min-height: 200rpx;
}

.custom-level-card {
  margin-top: 20rpx;
}

.thumb {
  width: 180rpx;
  height: 180rpx;
  border-radius: 28rpx;
  flex: 0 0 auto;
  box-shadow:
    12rpx 12rpx 24rpx rgba(2, 10, 18, 0.26),
    -8rpx -8rpx 16rpx rgba(102, 188, 224, 0.05);
}

.custom-level-main {
  flex: 1;
  margin-left: 20rpx;
}

.custom-meta {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #b8d3e2;
}

.button-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 20rpx;
}

.compact-btn {
  height: 84rpx;
  line-height: 84rpx;
  font-size: 28rpx;
}

.danger-btn {
  color: #ffd8cf;
  border-color: rgba(255, 176, 150, 0.18);
  background: linear-gradient(180deg, rgba(72, 39, 43, 0.5) 0%, rgba(42, 25, 30, 0.62) 100%);
}

.offscreen-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 720px;
  height: 720px;
  opacity: 0;
  pointer-events: none;
}
