.result-card {
  margin-top: 28rpx;
}

.result-badge {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.success {
  background: rgba(241, 191, 124, 0.14);
  color: #f1bf7c;
}

.fail {
  background: rgba(119, 173, 224, 0.14);
  color: #9ccaf8;
}

.result-title {
  margin-top: 18rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 24rpx;
}

.stats-cell {
  padding: 20rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.05);
}

.stats-label {
  font-size: 22rpx;
  color: #bcc7d8;
}

.stats-value {
  margin-top: 10rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.action-gap {
  margin-top: 22rpx;
}

.share-btn {
  margin-top: 18rpx;
}
