<view class="page-shell">
  <view class="page-title">{{level.title}}</view>
  <view class="page-subtitle">{{level.chapterTitle}} · {{level.sceneName}}</view>

  <view class="card preview-card">
    <image
      wx:if="{{level.sceneAssetPath}}"
      class="preview-scene preview-scene-image"
      src="{{level.sceneAssetPath}}"
      mode="aspectFill"
    ></image>
    <view wx:else class="preview-scene" style="background-image:{{level.sceneStyle}};"></view>
    <view class="chip preview-chip">{{level.clueTag}}</view>
    <view class="card-desc">{{level.introText}}</view>
  </view>

  <view class="card">
    <view class="row-between intro-row">
      <view class="card-title">本关目标</view>
      <view class="chip">{{level.rows}} x {{level.cols}}</view>
    </view>
    <view class="card-desc">
      在 {{level.timeLimit}} 秒内拼回完整图片。
      {{level.energyCost > 0 ? ('本关会消耗 ' + level.energyCost + ' 点体力') : '这是一关不消耗体力的自定义拼图'}}
      ，并自带 {{level.hints}} 次基础提示。
    </view>
    <view class="stats-grid">
      <view class="stats-cell">
        <view class="stats-label">当前体力</view>
        <view class="stats-value">{{profile.energy}} / {{profile.maxEnergy}}</view>
      </view>
      <view class="stats-cell">
        <view class="stats-label">通关奖励</view>
        <view class="stats-value">金币 +10 起</view>
      </view>
    </view>
    <button class="primary-btn start-btn" bindtap="handleStart">开始拼图</button>
  </view>
</view>
