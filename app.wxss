page {
  --sea-bg-0: #06131f;
  --sea-bg-1: #0a2030;
  --sea-bg-2: #12334a;
  --sea-panel: rgba(12, 35, 52, 0.56);
  --sea-panel-strong: rgba(10, 31, 47, 0.72);
  --sea-panel-soft: rgba(18, 53, 77, 0.36);
  --sea-line: rgba(177, 232, 255, 0.12);
  --sea-line-strong: rgba(177, 232, 255, 0.2);
  --sea-text: #eef9ff;
  --sea-text-soft: #b6d2e0;
  --sea-accent: #7ee0db;
  --sea-accent-deep: #2b9ec2;
  --sea-shadow: rgba(2, 10, 18, 0.45);
  --sea-highlight: rgba(228, 251, 255, 0.16);
  min-height: 100%;
  background:
    radial-gradient(circle at 18% 12%, rgba(108, 217, 255, 0.18), transparent 24%),
    radial-gradient(circle at 82% 8%, rgba(96, 169, 255, 0.12), transparent 22%),
    radial-gradient(circle at 50% 100%, rgba(44, 110, 154, 0.28), transparent 40%),
    linear-gradient(180deg, var(--sea-bg-2) 0%, var(--sea-bg-1) 38%, var(--sea-bg-0) 100%);
  color: var(--sea-text);
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}

view,
text,
button,
input,
textarea {
  box-sizing: border-box;
}

.page-shell {
  position: relative;
  min-height: 100vh;
  padding: 28rpx 28rpx 44rpx;
  background:
    radial-gradient(circle at 50% -10%, rgba(180, 240, 255, 0.12), transparent 28%),
    radial-gradient(circle at 0% 100%, rgba(69, 151, 210, 0.14), transparent 26%),
    radial-gradient(circle at 100% 72%, rgba(52, 92, 159, 0.14), transparent 22%);
}

.page-title {
  font-size: 54rpx;
  font-weight: 700;
  line-height: 1.14;
  letter-spacing: 1rpx;
  color: var(--sea-text);
  text-shadow: 0 8rpx 18rpx rgba(6, 16, 27, 0.28);
}

.page-subtitle {
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: var(--sea-text-soft);
}

.card {
  margin-top: 24rpx;
  padding: 28rpx;
  border-radius: 32rpx;
  background: linear-gradient(180deg, rgba(17, 48, 70, 0.62) 0%, rgba(8, 27, 42, 0.68) 100%);
  border: 1rpx solid var(--sea-line);
  backdrop-filter: blur(26rpx) saturate(140%);
  box-shadow:
    inset 0 2rpx 0 rgba(233, 251, 255, 0.12),
    inset 0 -14rpx 26rpx rgba(4, 14, 24, 0.22),
    18rpx 18rpx 36rpx var(--sea-shadow),
    -14rpx -14rpx 26rpx rgba(88, 171, 212, 0.06);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--sea-text);
}

.card-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--sea-text-soft);
}

.primary-btn,
.secondary-btn,
.ghost-btn {
  overflow: hidden;
}

.primary-btn {
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(169, 247, 255, 0.18);
  color: #effcff;
  background: linear-gradient(135deg, rgba(42, 134, 176, 0.96) 0%, rgba(99, 230, 212, 0.92) 100%);
  font-size: 30rpx;
  font-weight: 700;
  box-shadow:
    inset 0 2rpx 0 rgba(233, 251, 255, 0.26),
    inset 0 -10rpx 18rpx rgba(8, 58, 90, 0.22),
    16rpx 16rpx 32rpx rgba(2, 11, 20, 0.34),
    -10rpx -10rpx 20rpx rgba(105, 233, 255, 0.08);
}

.secondary-btn {
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 999rpx;
  border: 1rpx solid var(--sea-line);
  color: var(--sea-text);
  background: linear-gradient(180deg, rgba(18, 49, 70, 0.72) 0%, rgba(10, 31, 47, 0.8) 100%);
  font-size: 28rpx;
  box-shadow:
    inset 0 2rpx 0 rgba(236, 251, 255, 0.08),
    inset 0 -10rpx 18rpx rgba(4, 12, 19, 0.18),
    12rpx 12rpx 24rpx rgba(2, 10, 18, 0.28),
    -8rpx -8rpx 18rpx rgba(97, 186, 228, 0.05);
}

.ghost-btn {
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 999rpx;
  border: none;
  color: #d4edf7;
  background: rgba(255, 255, 255, 0.02);
  font-size: 26rpx;
}

.row {
  display: flex;
  align-items: center;
}

.row-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.chip {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #daf6ff;
  background: linear-gradient(180deg, rgba(24, 73, 101, 0.56) 0%, rgba(11, 37, 56, 0.62) 100%);
  border: 1rpx solid rgba(175, 231, 255, 0.12);
  box-shadow:
    inset 0 1rpx 0 rgba(228, 251, 255, 0.1),
    6rpx 6rpx 14rpx rgba(2, 10, 18, 0.22);
}

.muted {
  color: var(--sea-text-soft);
}

.section-title {
  margin-top: 32rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--sea-text);
}

.grid-two {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 20rpx;
}

.empty-tip {
  margin-top: 24rpx;
  padding: 30rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, rgba(16, 44, 63, 0.52) 0%, rgba(8, 25, 40, 0.58) 100%);
  border: 1rpx solid var(--sea-line);
  text-align: center;
  font-size: 24rpx;
  color: var(--sea-text-soft);
  box-shadow:
    inset 0 2rpx 0 rgba(227, 251, 255, 0.08),
    14rpx 14rpx 28rpx rgba(2, 10, 18, 0.28);
}
